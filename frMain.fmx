  object memAnnounce: TMemo
    Touch.InteractiveGestures = [Pan, LongTap, DoubleTap]
    DataDetectorTypes = []
    Lines.Strings = (
      'Project Configuration Notes'
      ''
      'Sidebar JSON Configuration'
      ''
      
        'The sidebar menu configuration uses JSON files located in the /a' +
        'ssets folder.'
      ''
      'Migration Menu Files'
      ''
      '/assets/list_menu_migrate_01.json'
      ''
      'Use this file for sidebar menu migration.'
      ''
      'Naming pattern:'
      ''
      'list_menu_migrate_01.json'
      'list_menu_migrate_02.json'
      'list_menu_migrate_03.json'
      '...'
      'list_menu_migrate_n.json'
      ''
      'Main Sidebar Menu File'
      ''
      '/assets/list_menuv2.json'
      ''
      
        'This is the main sidebar menu configuration file used by the app' +
        'lication.'
      ''
      'Push Notification Reference'
      ''
      'Push notification implementation reference:'
      ''
      'https://www.youtube.com/watch?v=xYYPTN1E9wg&t=742s'
      ''
      'Storage Access Framework / SAF'
      ''
      
        'Storage Access Framework is used to support Android file access ' +
        'using the Android file picker and FileProvider.'
      ''
      'Deployment Configuration'
      ''
      'Go to:'
      ''
      'Project > Deployment'
      ''
      'Make sure the following file is included:'
      ''
      'assets/file_path.xml'
      ''
      'Set the remote path to:'
      ''
      '.\res\xml'
      ''
      'Expected deployment mapping:'
      ''
      'Local Path  : assets/file_path.xml'
      'Remote Path : .\res\xml'
      ''
      'Android FileProvider Configuration'
      ''
      
        'The FileProvider authority must match the Android package name w' +
        'ith .fileprovider appended at the end.'
      ''
      'Format:'
      ''
      '{package_name}.fileprovider'
      ''
      'Example project name:'
      ''
      'FMXStarterKit'
      ''
      'Example Android package name:'
      ''
      'com.blangkon.FMXStarterKit'
      ''
      'Then the FileProvider authority must be:'
      ''
      'android:authorities="com.blangkon.FMXStarterKit.fileprovider"'
      ''
      'So this value:'
      ''
      'com.blangkon.FMXStarterKit.fileprovider'
      ''
      'must be consistent in:'
      ''
      '* Android Manifest provider configuration'
      '* Delphi/FileProvider configuration'
      '* Any SAF or file-sharing helper class'
      ''
      'Example provider configuration:'
      ''
      '<provider'
      ' android:name="androidx.core.content.FileProvider"'
      ' android:authorities="com.blangkon.FMXStarterKit.fileprovider"'
      ' android:exported="false"'
      ' android:grantUriPermissions="true">'
      ''
      '```'
      '<meta-data'
      '    android:name="android.support.FILE_PROVIDER_PATHS"'
      '    android:resource="@xml/file_path" />'
      '```'
      ''
      '</provider>'
      ''
      'Important:'
      ''
      
        'If the package name is changed, the FileProvider authority must ' +
        'also be updated.'
      ''
      'Example:'
      ''
      'Package Name : com.company.MyApp'
      'Authority    : com.company.MyApp.fileprovider')
    StyledSettings = [Style, FontColor]
